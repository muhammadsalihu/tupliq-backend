# Render Postgres connection string (from the database's "Internal Database URL"
# if the API and DB are both on Render, or "External Database URL" otherwise).
DATABASE_URL=postgresql://user:password@host:5432/tupliq

# Long random string used to sign JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=

# How long an access token stays valid.
JWT_EXPIRES_IN=30d

# Shared secret required (via the "x-admin-key" header) for admin-only endpoints
# (creating/editing hackathons, generating invite codes). Generate the same way
# as JWT_SECRET. Keep this only on the server / in an admin tool, never in the app.
ADMIN_API_KEY=

# Comma-separated list of origins allowed to call the API from a browser
# (the marketing site / any web build of the app). Native app requests aren't
# subject to CORS, so this only matters for web.
CORS_ORIGINS=http://localhost:8081

PORT=3000
